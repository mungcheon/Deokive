APP_NAME=Deokive API
APP_ENV=development
# Local dev:
DATABASE_URL=sqlite:///./deokive_dev.db
# Hosted Postgres example:
# DATABASE_URL=postgresql+psycopg://USER:PASSWORD@HOST/DBNAME?sslmode=require
JWT_SECRET_KEY=change-this-secret-key
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=10080
SOLE_ADMIN_LOGIN_ID=admin
SOLE_ADMIN_PASSWORD=deokiveadmin
SOLE_ADMIN_NICKNAME=관리자
